@model List<JuanApp.Models.Slider>
@{
	Layout = "~/Areas/Manage/Views/Shared/_AdminLayout.cshtml";
	ViewData["Title"] = "Sliders";
}

<div class="container-fluid">
	<div class="row pt-4">
		<div class="col-12">
			<div class="card">
				<div class="card-header d-flex justify-content-between align-items-center">
					<h3 class="card-title">Sliders Management</h3>
					<a asp-action="Create" class="btn btn-primary">Add New Slider</a>
				</div>
				<div class="card-body table-responsive">
					<table class="table table-bordered table-hover table-striped">
						<thead class="thead-dark">
							<tr>
								<th>ID</th>
								<th>Image</th>
								<th>Title</th>
								<th>Offer</th>
								<th>Button Text</th>
								<th class="text-center">Actions</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var item in Model)
							{
								<tr>
									<td>@item.Id</td>
									<td>
										@if (!string.IsNullOrEmpty(item.Image))
										{
											<img src="~/assets/img/slider/@item.Image" alt="@item.Title" width="100" class="img-thumbnail" />
										}
										else
										{
											<span class="text-muted">No Image</span>
										}
									</td>
									<td>@item.Title</td>
									<td>@item.Offer</td>
									<td>@item.BtnText</td>
									<td class="text-center">
										<div class="btn-group" role="group">
											<a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-info btn-sm">
												<i class="fas fa-eye"></i> Detail
											</a>
											<a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
												<i class="fas fa-edit"></i> Edit
											</a>
											<a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
												<i class="fas fa-trash"></i> Delete
											</a>
										</div>
									</td>
								</tr>
							}
							@if (!Model.Any())
							{
								<tr>
									<td colspan="6" class="text-center text-muted py-4">
										<i class="fas fa-images mb-2 d-block" style="font-size: 2rem;"></i>
										No sliders found in the database.
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
</div>