using JuanApp.Data;
using JuanApp.ViewModels;
using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;

namespace JuanApp.Controllers
{
    public class HomeController : Controller
    {
        private readonly JuanAppDbContext _context;

        public HomeController(JuanAppDbContext context)
        {
            _context = context;
        }

        public IActionResult Index()
        {
            HomeVm homeVm = new HomeVm()
            {
                Sliders = _context.Sliders.ToList(),
                OurProduct = _context.Products
                    .Include(x => x.Category)
                    .Where(x => !x.IsDeleted)
                    .Take(5)
                    .ToList(),
                NewProducts = _context.Products
                    .Include(x => x.Category)
                    .Where(x => !x.IsDeleted)
                    .OrderByDescending(x => x.Id)
                    .Take(6)
                    .ToList(),
                Categories = _context.Categories.ToList(),
                Blogs = _context.Blogs.Select(x => new BlogVm 
                {
                    Id = x.Id,
                    Title = x.Title,
                    ImageUrl = x.ImageUrl,
                    Author = x.Author,
                    CreatedAt = x.CreatedAt
                }).ToList()
            };

            return View(homeVm);
        }
    }
}
